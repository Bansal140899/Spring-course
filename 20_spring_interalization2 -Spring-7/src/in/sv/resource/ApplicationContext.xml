<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean class ="org.springframework.context.support.ResourceBundleMessageSource" id="rcm">
    <property name="basename"  value ="in/sv/resource/MessageBundle"></property>
    
    </bean>


<bean class="in.sv.beans.Student" id = "stdID">
<property name="msg"  ref="rcm"></property>

</bean>
</beans>
